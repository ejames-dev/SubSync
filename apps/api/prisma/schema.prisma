datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

model Service {
  id            String                  @id
  name          String
  category      String
  supportsOAuth Boolean                 @default(false)
  description   String?
  subscriptions Subscription[]
  integration   IntegrationConnection?
}

model IntegrationConnection {
  providerId   String   @id
  status       String
  source       String
  connectedAt  DateTime @default(now())
  lastSyncedAt DateTime?
  updatedAt    DateTime @updatedAt

  service Service @relation(fields: [providerId], references: [id], onDelete: Restrict)
}

model UserSettings {
  id                   String @id
  leadTimeDays         Int
  notificationChannels String
}

model Subscription {
  id                      String   @id @default(uuid())
  serviceId               String
  planName                String
  status                  String   @default("active")
  billingAmountCents      Int
  billingCurrency         String
  billingInterval         String   @default("monthly")
  nextRenewal             DateTime
  paymentSource           String?
  paymentLast4            String?
  autoImportSource        String?
  notes                   String?
  nextRenewalReminderSent Boolean  @default(false)
  statusChangedAt         DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  service Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  events  SubscriptionEvent[]
}

model SubscriptionEvent {
  id             String   @id @default(uuid())
  subscriptionId String
  eventType      String
  status         String
  notes          String?
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id           String   @id
  leadTimeDays Int      @default(7)
  channels     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
